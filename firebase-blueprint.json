{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string", "format": "url" },
        "role": { "type": "string", "enum": ["customer", "business"] },
        "createdAt": { "type": "number" }
      },
      "required": ["uid", "displayName", "email", "role"]
    },
    "Business": {
      "title": "Business",
      "description": "Local business information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" },
            "address": { "type": "string" }
          }
        },
        "phone": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "number" },
        "rating": { "type": "number" }
      },
      "required": ["name", "category", "location", "phone", "ownerId"]
    },
    "UserRequest": {
      "title": "UserRequest",
      "description": "Hyperlocal user request",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "budget": { "type": "number" },
        "deadline": { "type": "string" },
        "category": { "type": "string" },
        "urgency": { "type": "string", "enum": ["low", "medium", "high"] },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" },
            "address": { "type": "string" }
          }
        },
        "userId": { "type": "string" },
        "createdAt": { "type": "number" },
        "status": { "type": "string", "enum": ["open", "closed"] }
      },
      "required": ["title", "description", "category", "urgency", "location", "userId", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents"
    },
    "/businesses/{businessId}": {
      "schema": "Business",
      "description": "Business documents"
    },
    "/requests/{requestId}": {
      "schema": "UserRequest",
      "description": "User request documents"
    }
  }
}
